# Copy this to /home/ubuntu/algo_upstox/backend/.env on the Oracle VM

UPSTOX_API_KEY=your-key-here
UPSTOX_API_SECRET=your-secret-here

# IMPORTANT: must EXACTLY match what's registered in Upstox app -> Redirect URL.
# Change to your prod hostname (Caddy serves HTTPS for this):
UPSTOX_REDIRECT_URI=https://api.your-host.example.com/auth/callback

# Comma-separated origins allowed to call this backend. Add your Vercel URL.
FRONTEND_ORIGIN=https://your-app.vercel.app,http://localhost:5173

# Optional initial bootstrap for the tv.upstox.com session cookie.
# After first run this can be removed — tv_session.json takes over.
# UPSTOX_TV_COOKIE=

HOST=127.0.0.1
PORT=8000
